{
  "name": "ai-agent-os",
  "version": "1.0.0",
  "private": true,
  "description": "AI Agent OS — unified autonomous agent runtime integrating architectural ideas from Claude-Code and doge-code.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  },
  "bin": {
    "ai-agent-os": "./dist/cli/commands.js",
    "agentos": "./dist/cli/commands.js"
  },
  "scripts": {
    "dev": "bun run ./src/cli/commands.ts",
    "start": "node ./dist/cli/commands.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test --experimental-strip-types tests/unit/*.test.ts tests/unit/**/*.test.ts tests/integration/*.test.ts",
    "test:unit": "npm run build && node --test --experimental-strip-types tests/unit/*.test.ts tests/unit/**/*.test.ts",
    "test:integration": "npm run build && node --test --experimental-strip-types tests/integration/*.test.ts",
    "demo:security": "npm run build && node ./dist/demos/run-security-demo.js",
    "docker:build": "docker build -f docker/Dockerfile -t ai-agent-os:latest .",
    "docker:run": "docker compose -f docker/docker-compose.yml up --build",
    "gateway:dev": "node --experimental-strip-types --watch src/api-gateway/server.ts",
    "gateway:start": "node --experimental-strip-types src/api-gateway/server.ts",
    "stack:up": "docker compose -f docker-compose.yml up --build",
    "stack:down": "docker compose -f docker-compose.yml down"
  },
  "dependencies": {
    "@agentesting/agentest": "^0.0.18",
    "@anthropic-ai/sdk": "^0.40.1",
    "@arcadeai/arcadejs": "^2.3.0",
    "@composio/core": "^0.6.10",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nicofains1/agentwatch": "^0.3.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "execa": "^9.5.1",
    "fastify": "^5.1.0",
    "ink": "^5.0.1",
    "jose": "^5.9.6",
    "kavachos": "^0.4.2",
    "langfuse": "^3.38.20",
    "mem0ai": "^3.0.0",
    "mongodb": "^7.2.0",
    "openai": "^4.73.0",
    "openlit": "^1.11.0",
    "playwright": "^1.59.1",
    "pnpm-store": "link:/tmp/pnpm-store",
    "posthog-node": "^5.21.2",
    "react": "^18.3.1",
    "yaml": "^2.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "typescript": "^5.5.4",
    "vitest": "^2.0.0"
  },
  "scripts": {
    "dev": "bun run ./src/cli/commands.ts",
    "start": "node ./dist/cli/commands.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:unit:watch": "vitest tests/unit --watch",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration",
    "demo:security": "npm run build && node ./dist/demos/run-security-demo.js",
    "docker:build": "docker build -f docker/Dockerfile -t ai-agent-os:latest .",
    "docker:run": "docker compose -f docker/docker-compose.yml up --build",
    "gateway:dev": "node --experimental-strip-types --watch src/api-gateway/server.ts",
    "gateway:start": "node --experimental-strip-types src/api-gateway/server.ts",
    "stack:up": "docker compose -f docker-compose.yml up --build",
    "stack:down": "docker compose -f docker-compose.yml down"
  }
