{
  "name": "ai-agent-os",
  "version": "1.0.0",
  "private": true,
  "description": "AI Agent OS — unified autonomous agent runtime integrating architectural ideas from Claude-Code and doge-code.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  },
  "bin": {
    "ai-agent-os": "./dist/cli/commands.js",
    "agentos": "./dist/cli/commands.js"
  },
  "scripts": {
    "dev": "bun run ./src/cli/commands.ts",
    "start": "node ./dist/cli/commands.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test --experimental-strip-types tests/unit/*.test.ts tests/integration/*.test.ts",
    "test:unit": "npm run build && node --test --experimental-strip-types tests/unit/*.test.ts",
    "test:integration": "npm run build && node --test --experimental-strip-types tests/integration/*.test.ts",
    "docker:build": "docker build -f docker/Dockerfile -t ai-agent-os:latest .",
    "docker:run": "docker compose -f docker/docker-compose.yml up --build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "execa": "^9.5.1",
    "ink": "^5.0.1",
    "openai": "^4.73.0",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "typescript": "^5.5.4"
  }
}
