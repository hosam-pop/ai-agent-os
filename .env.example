# =============================================================================
# AI Agent OS — Environment Variables
# Copy this file to `.env` and fill in values for the providers you want to use.
# =============================================================================

# -----------------------------------------------------------------------------
# Primary provider: anthropic | openai | custom | router | octoroute
#   router    -> use the built-in multi-provider router (see DOGE_ROUTER_CONFIG)
#   octoroute -> forward to a local OpenAI-compatible gateway (Ollama, LM Studio)
# -----------------------------------------------------------------------------
DOGE_PROVIDER=anthropic

# -----------------------------------------------------------------------------
# Default model per provider (used when no model is passed to `run` command).
# -----------------------------------------------------------------------------
DOGE_MODEL=claude-3-5-sonnet-latest

# -----------------------------------------------------------------------------
# Anthropic
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# -----------------------------------------------------------------------------
# OpenAI (and any OpenAI-compatible custom provider)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# Custom OpenAI-compatible endpoint (used when DOGE_PROVIDER=custom)
# -----------------------------------------------------------------------------
DOGE_CUSTOM_BASE_URL=
DOGE_CUSTOM_API_KEY=
DOGE_CUSTOM_MODEL=

# -----------------------------------------------------------------------------
# Storage paths (defaults mirror doge-code's ~/.doge/ layout).
# -----------------------------------------------------------------------------
DOGE_HOME=
DOGE_WORKSPACE=

# -----------------------------------------------------------------------------
# Safety / permissions
# DOGE_PERMISSION_MODE = strict | default | permissive
# DOGE_ALLOW_NETWORK   = true | false (web-tool allowance)
# DOGE_ALLOW_WRITES    = true | false (file-tool write allowance)
# -----------------------------------------------------------------------------
DOGE_PERMISSION_MODE=default
DOGE_ALLOW_NETWORK=true
DOGE_ALLOW_WRITES=true

# -----------------------------------------------------------------------------
# Logging: debug | info | warn | error
# -----------------------------------------------------------------------------
DOGE_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Feature gates (ported from Claude-Code; disabled by default).
# -----------------------------------------------------------------------------
DOGE_FEATURE_BUDDY=false
DOGE_FEATURE_KAIROS=false
DOGE_FEATURE_ULTRAPLAN=false
DOGE_FEATURE_COORDINATOR=false
DOGE_FEATURE_BRIDGE=false

# -----------------------------------------------------------------------------
# Ultimate integrations — AdminTool is on by default, the rest opt-in.
# -----------------------------------------------------------------------------
DOGE_FEATURE_ADMIN=true
DOGE_FEATURE_BROWSER=false
DOGE_FEATURE_MEM0=false
DOGE_FEATURE_MCP=false
DOGE_FEATURE_ROUTER=false
DOGE_FEATURE_SOCIAL=false
DOGE_FEATURE_OCTOROUTE=false

# -----------------------------------------------------------------------------
# mem0 semantic memory (https://github.com/mem0ai/mem0)
# Leave MEM0_API_KEY empty to fall back to the local long-term memory store.
# -----------------------------------------------------------------------------
MEM0_API_KEY=
MEM0_ORG_ID=
MEM0_PROJECT_ID=
MEM0_USER_ID=ai-agent-os-default

# -----------------------------------------------------------------------------
# MCP (Model Context Protocol) — connect to ultimate_mcp_server, 0nMCP, etc.
# Use either MCP_SERVER_URL (HTTP/SSE) or MCP_SERVER_STDIO (command to spawn).
# -----------------------------------------------------------------------------
MCP_SERVER_URL=
MCP_SERVER_TOKEN=
MCP_SERVER_STDIO=

# -----------------------------------------------------------------------------
# Multi-provider router (enabled when DOGE_PROVIDER=router).
# DOGE_ROUTER_CONFIG can be inline JSON or a path to a JSON file describing
# the providers array. Strategies: failover | round-robin | weighted | least-recent
# -----------------------------------------------------------------------------
DOGE_ROUTER_CONFIG=
DOGE_ROUTER_STRATEGY=failover

# -----------------------------------------------------------------------------
# Octoroute (local LLM gateway, OpenAI-compatible — Ollama/LM Studio/etc.)
# -----------------------------------------------------------------------------
OCTOROUTE_URL=
OCTOROUTE_API_KEY=
OCTOROUTE_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Social channels (Telegram + Slack adapters under src/integrations/openclaw/)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=

# -----------------------------------------------------------------------------
# Browser automation (Playwright — install with `npx playwright install`)
# -----------------------------------------------------------------------------
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=30000
BROWSER_EXECUTABLE_PATH=

# -----------------------------------------------------------------------------
# Agent loop tuning
# -----------------------------------------------------------------------------
DOGE_MAX_ITERATIONS=25
DOGE_MAX_PARALLEL_TASKS=4
DOGE_CONTEXT_TOKEN_BUDGET=120000

# -----------------------------------------------------------------------------
# Defensive security tooling (all disabled by default — opt-in per family).
#   SAST          : Semgrep / CodeQL source analysis
#   DAST          : Nuclei / OWASP ZAP running scans (only against authorised assets)
#   LOG_ANALYSIS  : Elasticsearch / Wazuh clients
#   IDS           : Suricata eve.json reader
# -----------------------------------------------------------------------------
DOGE_FEATURE_SAST=false
DOGE_FEATURE_DAST=false
DOGE_FEATURE_LOG_ANALYSIS=false
DOGE_FEATURE_IDS=false

# -----------------------------------------------------------------------------
# Advanced defensive tooling (extends the base families above).
#   CONTAINER_SCAN   : Grype / Trivy image & SBOM vulnerability scanners
#   RUNTIME_MONITOR  : Falco eve-style JSON log reader
#   ORCHESTRATION    : library-level flag for the src/orchestration primitives
# -----------------------------------------------------------------------------
DOGE_FEATURE_CONTAINER_SCAN=false
DOGE_FEATURE_RUNTIME_MONITOR=false
DOGE_FEATURE_ORCHESTRATION=false

# Override binary locations if they are not on $PATH.
SEMGREP_BIN=
CODEQL_BIN=
BEARER_BIN=
NUCLEI_BIN=
ZAP_BIN=
GRYPE_BIN=
TRIVY_BIN=

# Falco JSON output (default: /var/log/falco/falco.json)
FALCO_LOG_PATH=

# Elasticsearch / ELK (use ELASTIC_API_KEY *or* username+password, not both).
ELASTIC_URL=
ELASTIC_API_KEY=
ELASTIC_USERNAME=
ELASTIC_PASSWORD=

# Wazuh REST API.
WAZUH_URL=
WAZUH_USERNAME=
WAZUH_PASSWORD=
WAZUH_TOKEN=

# Suricata eve.json absolute path (default Linux: /var/log/suricata/eve.json).
SURICATA_EVE_PATH=

# -----------------------------------------------------------------------------
# Defensive LLM guard, threat intel, and detection engineering (all opt-in).
#   LLM_GUARD      : Vigil (https://github.com/deadbits/vigil-llm) prompt-injection
#                    and PII scanner. Talks to a locally-run Vigil HTTP service.
#   THREAT_INTEL   : OSV.dev public vulnerability database. Requires no auth.
#   DETECTION_ENG  : Atomic Red Team YAML reader for detection engineering.
#                    Exposes technique metadata only — never executes tests.
# -----------------------------------------------------------------------------
DOGE_FEATURE_LLM_GUARD=false
DOGE_FEATURE_THREAT_INTEL=false
DOGE_FEATURE_DETECTION_ENG=false

# Vigil service (http://localhost:5000 when you run the upstream docker image).
VIGIL_URL=
VIGIL_TOKEN=

# OSV.dev override (defaults to https://api.osv.dev — leave blank for default).
OSV_URL=

# Absolute path to a local clone of https://github.com/redcanaryco/atomic-red-team
# The reader walks $ATOMIC_RED_TEAM_PATH/atomics/<Txxxx>/<Txxxx>.yaml.
ATOMIC_RED_TEAM_PATH=

# -----------------------------------------------------------------------------
# Advanced Weapons — defensive/technical integrations (all opt-in, default off)
#   MCP_GATEWAY   : Lasso+Guardian-style policy layer in front of MCPClient
#                   (allowlist/denylist, rate-limit, optional Vigil response scan).
#   LETTA         : Stateful-memory adapter for https://github.com/letta-ai/letta
#   ZEP           : Long-term memory adapter for https://github.com/getzep/zep
#   VECTOR_STORES : Unified Qdrant + Chroma + LanceDB vector-store tool.
#   RAG           : LlamaIndex-backed retrieval engine under src/rag/.
#   SKILL_PLANNER : Semantic-Kernel-style goal->skill planner (native TS).
#   STAGEHAND     : Second browser automation engine via @browserbasehq/stagehand
#                   (dynamic import, does not add to build graph).
#   CODEQL_MCP    : External CodeQL MCP server proxy (Jordy Zomer's codeql-mcp).
#   SEMGREP_MCP   : External Semgrep MCP server proxy (VetCoders/mcp-server-semgrep).
# -----------------------------------------------------------------------------
DOGE_FEATURE_MCP_GATEWAY=false
DOGE_FEATURE_LETTA=false
DOGE_FEATURE_ZEP=false
DOGE_FEATURE_VECTOR_STORES=false
DOGE_FEATURE_RAG=false
DOGE_FEATURE_SKILL_PLANNER=false
DOGE_FEATURE_STAGEHAND=false
DOGE_FEATURE_CODEQL_MCP=false
DOGE_FEATURE_SEMGREP_MCP=false

# MCP gateway policy (comma-separated tool names).
MCP_GATEWAY_ALLOW_TOOLS=
MCP_GATEWAY_DENY_TOOLS=
MCP_GATEWAY_RATE_LIMIT=
MCP_GATEWAY_WINDOW_MS=
MCP_GATEWAY_SCAN_RESPONSES=false

# Letta stateful-memory service.
LETTA_URL=
LETTA_TOKEN=
LETTA_AGENT_ID=

# Zep long-term memory service.
ZEP_URL=
ZEP_API_KEY=
ZEP_SESSION_ID=

# Vector stores (pick the default backend; individual adapters fall back to env
# detection: QDRANT_URL -> qdrant, CHROMA_URL -> chroma, else lancedb on disk).
VECTOR_STORE_BACKEND=
QDRANT_URL=
QDRANT_API_KEY=
CHROMA_URL=
CHROMA_TOKEN=
LANCEDB_URI=

# Stagehand browser automation (@browserbasehq/stagehand).
# Leave BROWSERBASE_* blank to run Stagehand locally with Playwright.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
STAGEHAND_MODEL_NAME=

# External MCP servers for static-analysis tooling.
# Launch the upstream server separately, then point these vars at it.
#   CodeQL MCP  -> https://github.com/JordyZomer/codeql-mcp
#   Semgrep MCP -> https://github.com/VetCoders/mcp-server-semgrep
CODEQL_MCP_URL=
CODEQL_MCP_STDIO=
SEMGREP_MCP_URL=
SEMGREP_MCP_STDIO=
