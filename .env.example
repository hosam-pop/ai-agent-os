# =============================================================================
# AI Agent OS — Environment Variables
# Copy this file to `.env` and fill in values for the providers you want to use.
# =============================================================================

# -----------------------------------------------------------------------------
# Primary provider: anthropic | openai | custom | router | octoroute
#   router    -> use the built-in multi-provider router (see DOGE_ROUTER_CONFIG)
#   octoroute -> forward to a local OpenAI-compatible gateway (Ollama, LM Studio)
# -----------------------------------------------------------------------------
DOGE_PROVIDER=anthropic

# -----------------------------------------------------------------------------
# Default model per provider (used when no model is passed to `run` command).
# -----------------------------------------------------------------------------
DOGE_MODEL=claude-3-5-sonnet-latest

# -----------------------------------------------------------------------------
# Anthropic
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# -----------------------------------------------------------------------------
# OpenAI (and any OpenAI-compatible custom provider)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# Custom OpenAI-compatible endpoint (used when DOGE_PROVIDER=custom)
# -----------------------------------------------------------------------------
DOGE_CUSTOM_BASE_URL=
DOGE_CUSTOM_API_KEY=
DOGE_CUSTOM_MODEL=

# -----------------------------------------------------------------------------
# Storage paths (defaults mirror doge-code's ~/.doge/ layout).
# -----------------------------------------------------------------------------
DOGE_HOME=
DOGE_WORKSPACE=

# -----------------------------------------------------------------------------
# Safety / permissions
# DOGE_PERMISSION_MODE = strict | default | permissive
# DOGE_ALLOW_NETWORK   = true | false (web-tool allowance)
# DOGE_ALLOW_WRITES    = true | false (file-tool write allowance)
# -----------------------------------------------------------------------------
DOGE_PERMISSION_MODE=default
DOGE_ALLOW_NETWORK=true
DOGE_ALLOW_WRITES=true

# -----------------------------------------------------------------------------
# Logging: debug | info | warn | error
# -----------------------------------------------------------------------------
DOGE_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Feature gates (ported from Claude-Code; disabled by default).
# -----------------------------------------------------------------------------
DOGE_FEATURE_BUDDY=false
DOGE_FEATURE_KAIROS=false
DOGE_FEATURE_ULTRAPLAN=false
DOGE_FEATURE_COORDINATOR=false
DOGE_FEATURE_BRIDGE=false

# -----------------------------------------------------------------------------
# Ultimate integrations — AdminTool is on by default, the rest opt-in.
# -----------------------------------------------------------------------------
DOGE_FEATURE_ADMIN=true
DOGE_FEATURE_BROWSER=false
DOGE_FEATURE_MEM0=false
DOGE_FEATURE_MCP=false
DOGE_FEATURE_ROUTER=false
DOGE_FEATURE_SOCIAL=false
DOGE_FEATURE_OCTOROUTE=false

# -----------------------------------------------------------------------------
# mem0 semantic memory (https://github.com/mem0ai/mem0)
# Leave MEM0_API_KEY empty to fall back to the local long-term memory store.
# -----------------------------------------------------------------------------
MEM0_API_KEY=
MEM0_ORG_ID=
MEM0_PROJECT_ID=
MEM0_USER_ID=ai-agent-os-default

# -----------------------------------------------------------------------------
# MCP (Model Context Protocol) — connect to ultimate_mcp_server, 0nMCP, etc.
# Use either MCP_SERVER_URL (HTTP/SSE) or MCP_SERVER_STDIO (command to spawn).
# -----------------------------------------------------------------------------
MCP_SERVER_URL=
MCP_SERVER_TOKEN=
MCP_SERVER_STDIO=

# -----------------------------------------------------------------------------
# Multi-provider router (enabled when DOGE_PROVIDER=router).
# DOGE_ROUTER_CONFIG can be inline JSON or a path to a JSON file describing
# the providers array. Strategies: failover | round-robin | weighted | least-recent
# -----------------------------------------------------------------------------
DOGE_ROUTER_CONFIG=
DOGE_ROUTER_STRATEGY=failover

# -----------------------------------------------------------------------------
# Octoroute (local LLM gateway, OpenAI-compatible — Ollama/LM Studio/etc.)
# -----------------------------------------------------------------------------
OCTOROUTE_URL=
OCTOROUTE_API_KEY=
OCTOROUTE_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Social channels (Telegram + Slack adapters under src/integrations/openclaw/)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=

# -----------------------------------------------------------------------------
# Browser automation (Playwright — install with `npx playwright install`)
# -----------------------------------------------------------------------------
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=30000
BROWSER_EXECUTABLE_PATH=

# -----------------------------------------------------------------------------
# Agent loop tuning
# -----------------------------------------------------------------------------
DOGE_MAX_ITERATIONS=25
DOGE_MAX_PARALLEL_TASKS=4
DOGE_CONTEXT_TOKEN_BUDGET=120000
