# =============================================================================
# AI Agent OS — Environment Variables
# Copy this file to `.env` and fill in values for the providers you want to use.
# =============================================================================

# -----------------------------------------------------------------------------
# Primary provider: anthropic | openai | custom
# -----------------------------------------------------------------------------
DOGE_PROVIDER=anthropic

# -----------------------------------------------------------------------------
# Default model per provider (used when no model is passed to `run` command).
# -----------------------------------------------------------------------------
DOGE_MODEL=claude-3-5-sonnet-latest

# -----------------------------------------------------------------------------
# Anthropic
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# -----------------------------------------------------------------------------
# OpenAI (and any OpenAI-compatible custom provider)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# Custom OpenAI-compatible endpoint (used when DOGE_PROVIDER=custom)
# -----------------------------------------------------------------------------
DOGE_CUSTOM_BASE_URL=
DOGE_CUSTOM_API_KEY=
DOGE_CUSTOM_MODEL=

# -----------------------------------------------------------------------------
# Storage paths (defaults mirror doge-code's ~/.doge/ layout).
# -----------------------------------------------------------------------------
DOGE_HOME=
DOGE_WORKSPACE=

# -----------------------------------------------------------------------------
# Safety / permissions
# DOGE_PERMISSION_MODE = strict | default | permissive
# DOGE_ALLOW_NETWORK   = true | false (web-tool allowance)
# DOGE_ALLOW_WRITES    = true | false (file-tool write allowance)
# -----------------------------------------------------------------------------
DOGE_PERMISSION_MODE=default
DOGE_ALLOW_NETWORK=true
DOGE_ALLOW_WRITES=true

# -----------------------------------------------------------------------------
# Logging: debug | info | warn | error
# -----------------------------------------------------------------------------
DOGE_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Feature gates (ported from Claude-Code; disabled by default).
# -----------------------------------------------------------------------------
DOGE_FEATURE_BUDDY=false
DOGE_FEATURE_KAIROS=false
DOGE_FEATURE_ULTRAPLAN=false
DOGE_FEATURE_COORDINATOR=false
DOGE_FEATURE_BRIDGE=false

# -----------------------------------------------------------------------------
# Agent loop tuning
# -----------------------------------------------------------------------------
DOGE_MAX_ITERATIONS=25
DOGE_MAX_PARALLEL_TASKS=4
DOGE_CONTEXT_TOKEN_BUDGET=120000
