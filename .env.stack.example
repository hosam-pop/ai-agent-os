# ==============================================================================
# AI Agent OS — Unified Platform Stack
# Copy to .env.stack and fill in. NEVER commit the real .env.stack file.
# Generate each secret with: openssl rand -base64 32
# ==============================================================================

# -----------------------------------------------------------------------------
# Keycloak
# -----------------------------------------------------------------------------
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_PUBLIC_ISSUER=http://localhost:8080/realms/ai-agent-os
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_openssl_rand_base64_32
KEYCLOAK_DB_PASSWORD=CHANGE_ME_openssl_rand_base64_32

# OIDC client secrets (generated by Keycloak after realm import; copy from
# admin console → Clients → <id> → Credentials)
OPENID_CLIENT_SECRET_LIBRECHAT=CHANGE_ME
OPENID_SESSION_SECRET=CHANGE_ME_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# API Gateway
# -----------------------------------------------------------------------------
GATEWAY_PORT=4000
GATEWAY_RATE_LIMIT_MAX=300
GATEWAY_RATE_LIMIT_WINDOW=1 minute
GATEWAY_CORS_ORIGINS=http://localhost:3080,http://localhost:3000

# -----------------------------------------------------------------------------
# LibreChat
# -----------------------------------------------------------------------------
LIBRECHAT_PORT=3080
LIBRECHAT_PUBLIC_URL=http://localhost:3080
# 32-char hex (openssl rand -hex 32) for CREDS_KEY, 16-char hex for CREDS_IV
LIBRECHAT_CREDS_KEY=CHANGE_ME_hex64
LIBRECHAT_CREDS_IV=CHANGE_ME_hex32
LIBRECHAT_JWT_SECRET=CHANGE_ME_openssl_rand_base64_32
LIBRECHAT_JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# Meilisearch
# -----------------------------------------------------------------------------
MEILI_MASTER_KEY=CHANGE_ME_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# Mission Control (basic auth fallback — upstream does not support OIDC)
# -----------------------------------------------------------------------------
MISSION_CONTROL_USER=admin
MISSION_CONTROL_PASS=CHANGE_ME_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# AI Agent OS core (carry over from .env.example)
# -----------------------------------------------------------------------------
DOGE_PROVIDER=anthropic
DOGE_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
