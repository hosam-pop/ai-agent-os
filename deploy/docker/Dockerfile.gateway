# syntax=docker/dockerfile:1.7
# ============================================================================
# AI Agent OS — Unified API Gateway
# Builds the Fastify gateway as a production Node 20 image (distroless).
# ============================================================================

FROM node:20-bookworm-slim AS build
WORKDIR /app

# Copy only what's needed for deterministic install
COPY package.json package-lock.json* ./
RUN npm ci --omit=optional --no-audit --no-fund

COPY tsconfig.json ./
COPY src ./src
RUN npm run build \
  && npm prune --omit=dev

FROM gcr.io/distroless/nodejs20-debian12 AS runtime
WORKDIR /app

ENV NODE_ENV=production
ENV GATEWAY_HOST=0.0.0.0
ENV GATEWAY_PORT=4000

COPY --from=build /app/node_modules /app/node_modules
COPY --from=build /app/dist /app/dist
COPY --from=build /app/package.json /app/package.json

EXPOSE 4000
USER nonroot
CMD ["/app/dist/api-gateway/server.js"]
