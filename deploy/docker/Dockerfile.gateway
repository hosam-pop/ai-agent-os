# syntax=docker/dockerfile:1.7
# ============================================================================
# AI Agent OS — Unified API Gateway
# Builds the Fastify gateway as a production Node 20 image (distroless).
# ============================================================================

FROM node:20-bookworm-slim AS build
WORKDIR /app

# Copy only what's needed for deterministic install
COPY package.json package-lock.json* ./
RUN npm ci --omit=optional --no-audit --no-fund

COPY tsconfig.json ./
COPY src ./src
RUN npm run build \
  && npm prune --omit=dev

FROM node:20-bookworm-slim AS runtime
WORKDIR /app

ENV NODE_ENV=production \
    GATEWAY_HOST=0.0.0.0 \
    GATEWAY_PORT=4000 \
    KEYS_STORE_PATH=/data/admin-keys.json

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates tini \
  && rm -rf /var/lib/apt/lists/* \
  && groupadd --system --gid 1001 aaos \
  && useradd --system --uid 1001 --gid aaos --no-create-home aaos \
  && mkdir -p /data \
  && chown -R aaos:aaos /data /app

COPY --from=build --chown=aaos:aaos /app/node_modules /app/node_modules
COPY --from=build --chown=aaos:aaos /app/dist /app/dist
COPY --from=build --chown=aaos:aaos /app/package.json /app/package.json
COPY --chown=aaos:aaos deploy/docker/gateway-entrypoint.sh /usr/local/bin/gateway-entrypoint.sh
RUN chmod +x /usr/local/bin/gateway-entrypoint.sh

EXPOSE 4000
USER aaos
ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/gateway-entrypoint.sh"]
CMD ["node", "/app/dist/api-gateway/server.js"]
